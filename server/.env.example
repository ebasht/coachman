PORT=3001
# PostgreSQL:
# DATABASE_URL=postgres://user:pass@host:5432/coachman?sslmode=disable
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173,http://localhost:3001
BOOTSTRAP_TOKEN=change-me-bootstrap-token
INVITE_TTL_HOURS=168

# Web Push (PWA уведомления в фоне). Сгенерировать: npm run generate:vapid
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Email без mailto: (библиотека сама добавит) ИЛИ HTTPS URL сайта:
# VAPID_SUBJECT=https://coachman.eugen-bash.com/
# Должен совпадать с id в PWA-манифесте (VITE_PWA_ID при сборке клиента):
# PWA_MANIFEST_ID=https://coachman.eugen-bash.com/

# WebRTC TURN (видеозвонки через NAT). Без TURN работают только в одной сети / с простым NAT.
# TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# TURN_USERNAME=coachman
# TURN_CREDENTIAL=secret
# Опционально свой список STUN (по умолчанию Google):
# STUN_URLS=stun:stun.l.google.com:19302
# Или полный JSON ICE (перекрывает STUN/TURN_*):
# ICE_SERVERS_JSON=[{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]

# Опционально: Redis для fan-out WebSocket между инстансами
# REDIS_URL=redis://localhost:6379

# Fallback на SQLite (если DATABASE_URL не задан):
# DB_PATH=data/coachman.db

# Object storage (опционально; без S3_ENDPOINT — BLOB в PostgreSQL)
# MinIO локально:
# S3_ENDPOINT=localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=coachman
#
# Yandex Object Storage:
# S3_ENDPOINT=storage.yandexcloud.net
# S3_REGION=ru-central1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_BUCKET=coachman
