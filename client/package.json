{
  "name": "client",
  "version": "1.0.13",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:icons": "node scripts/generate-icons.mjs",
    "prebuild": "npm run generate:icons",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "reset:db": "node scripts/reset-db.mjs",
    "cap:sync": "npm run build && set -a && [ -f .env ] && . ./.env; set +a && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "set -a && [ -f .env ] && . ./.env; set +a && npx cap run android",
    "android:sync": "npm run cap:sync"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "idb": "^8.0.2",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.35.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^0.21.1",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.7",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  }
}
