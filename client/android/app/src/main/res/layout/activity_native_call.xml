<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/native_call_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05050A">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/native_remote_renderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Waiting / ring stage (FaceTime-like) -->
    <LinearLayout
        android:id="@+id/native_call_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="28dp"
        android:paddingTop="72dp"
        android:paddingRight="28dp"
        android:paddingBottom="48dp">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <FrameLayout
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_gravity="center_horizontal">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_call_avatar_circle" />

            <TextView
                android:id="@+id/native_call_avatar_letter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/incomingCallText"
                android:textSize="44sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/native_call_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:letterSpacing="-0.02"
            android:text="Собеседник"
            android:textColor="@color/incomingCallText"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/native_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Подключение видео…"
            android:textColor="@color/incomingCallMuted"
            android:textSize="16sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1.35" />
    </LinearLayout>

    <!-- Local PiP -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/native_local_renderer"
        android:layout_width="108dp"
        android:layout_height="152dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="16dp"
        android:elevation="8dp"
        android:visibility="gone" />

    <View
        android:id="@+id/native_call_top_scrim"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_call_top_scrim" />

    <View
        android:id="@+id/native_call_bottom_scrim"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_call_bottom_scrim" />

    <!-- Live top chrome (name over video) -->
    <FrameLayout
        android:id="@+id/native_live_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="56dp"
            android:layout_marginEnd="56dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/native_live_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:textColor="@color/incomingCallText"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/native_live_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/native_btn_minimize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_call_glass_circle"
            android:contentDescription="Свернуть звонок"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_call_minimize"
            android:stateListAnimator="@null" />
    </FrameLayout>

    <!-- Incoming: Accept / Decline -->
    <LinearLayout
        android:id="@+id/native_call_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="44dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/native_btn_reject"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_call_decline_circle"
                    android:contentDescription="Отклонить"
                    android:elevation="8dp"
                    android:padding="22dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_call_decline"
                    android:stateListAnimator="@null" />

                <TextView
                    android:id="@+id/native_label_reject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Отклонить"
                    android:textColor="#B8FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/native_btn_accept"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_call_accept_circle"
                    android:contentDescription="Ответить"
                    android:elevation="8dp"
                    android:padding="22dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_call_accept"
                    android:stateListAnimator="@null" />

                <TextView
                    android:id="@+id/native_label_accept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Ответить"
                    android:textColor="#B8FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/native_btn_perm_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="?android:attr/selectableItemBackground"
            android:padding="10dp"
            android:text="Открыть настройки"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- In-call controls -->
    <LinearLayout
        android:id="@+id/native_active_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="40dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/native_btn_mute"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_call_glass_circle"
                android:contentDescription="Микрофон"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_mic"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/native_label_mute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Микрофон"
                android:textColor="#B8FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/native_btn_camera"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_call_glass_circle"
                android:contentDescription="Камера"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_video"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/native_label_camera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Камера"
                android:textColor="#B8FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/native_btn_switch"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_call_glass_circle"
                android:contentDescription="Смена камеры"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_flip"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Смена"
                android:textColor="#B8FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/native_btn_hangup"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_call_decline_circle"
                android:contentDescription="Завершить"
                android:elevation="6dp"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_call_decline"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Завершить"
                android:textColor="#B8FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
