<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/native_call_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/native_remote_renderer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/native_call_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/native_call_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/native_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Подключение видео…"
            android:textColor="#CBD5E1"
            android:textSize="16sp" />
    </LinearLayout>

    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/native_local_renderer"
        android:layout_width="110dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/native_call_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/native_btn_reject"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:backgroundTint="#DC2626"
                android:text="Отклонить"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/native_btn_accept"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:backgroundTint="#16A34A"
                android:text="Ответить"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <Button
            android:id="@+id/native_btn_perm_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="Открыть настройки"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/native_active_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="20dp"
        android:visibility="gone">

        <Button
            android:id="@+id/native_btn_mute"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Микрофон" />

        <Button
            android:id="@+id/native_btn_camera"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="Камера" />

        <Button
            android:id="@+id/native_btn_switch"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="Смена" />

        <Button
            android:id="@+id/native_btn_hangup"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#DC2626"
            android:text="Сброс"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</FrameLayout>
