{
  "name": "coachman",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client"
  ],
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execFileSync('git',['rev-parse','--git-dir'],{stdio:'ignore'});require('child_process').execFileSync('git',['config','core.hooksPath','.githooks'],{stdio:'ignore'})}catch{}\"",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "sh -c '(lsof -ti :3001 | xargs kill -9) 2>/dev/null || true; cd server && COACHMAN_DEV=1 go run ./cmd/api'",
    "dev:client": "sh -c 'until curl -sf http://127.0.0.1:3001/health >/dev/null 2>&1; do sleep 0.3; done; npm run dev -w client'",
    "migrate": "cd server && go run ./cmd/migrate",
    "reset:db": "cd server && go run ./cmd/resetdb",
    "generate:vapid": "cd server && go run ./cmd/generate-vapid",
    "build": "npm run build -w client && cd server && CGO_ENABLED=0 go build -o bin/api ./cmd/api",
    "start": "cd server && ./bin/api",
    "test:server": "cd server && go test ./...",
    "android:sync": "npm run android:sync -w client",
    "android:open": "npm run android:open -w client",
    "android:run": "npm run android:run -w client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
